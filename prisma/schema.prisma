generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH MODELS (NextAuth / Auth.js)
// ============================================

enum UserRole {
  USER
  ADMIN
}

enum UserPlan {
  FREE
  PREMIUM
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  role           UserRole  @default(USER)
  plan           UserPlan  @default(FREE)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  savedAnalyses  SavedAnalysis[]
  searchHistory  SearchHistory[]
  apiUsage       ApiUsage[]
  aiFeedback     AiFeedback[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// APP MODELS
// ============================================

model SavedAnalysis {
  id        String   @id @default(cuid())
  userId    String
  hotelName String
  location  String
  aiScore   Float?
  analysis  Json?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  query     String
  results   Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model HotelCache {
  id                String   @id @default(cuid())
  externalId        String?
  name              String
  location          String
  rawReviews        Json?
  aiAnalysis        Json?
  aiScore           Float?
  sources           String[]
  lastScraped       DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Google Places fields
  googlePlaceId     String?
  latitude          Float?
  longitude         Float?
  googleRating      Float?
  googleReviewCount Int?
  googlePhotos      Json?
  googleReviews     Json?
  nearbyPlaces      Json?
  geminiAnalysis    Json?

  @@unique([name, location])
  @@index([location])
}

// ============================================
// API USAGE & COST TRACKING
// ============================================

model ApiUsage {
  id           String   @id @default(cuid())
  userId       String
  type         String   // "search" | "analyze"
  model        String   // "haiku" | "sonnet"
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costUsd      Float    @default(0)
  query        String?
  cached       Boolean  @default(false)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([type])
  @@index([model])
}

// ============================================
// AI FEEDBACK (user verification loop)
// ============================================

model AiFeedback {
  id           String   @id @default(cuid())
  userId       String
  hotelCacheId String
  category     String   // "overall" | "lokacija" | "cistoca" | etc.
  isCorrect    Boolean  // true = "AI je u pravu", false = "AI je pogresio"
  comment      String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hotelCacheId, category])
  @@index([hotelCacheId])
}

// Search cache za destinacije (ne samo hotele)
model SearchCache {
  id        String   @id @default(cuid())
  query     String   @unique
  results   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([query])
}
